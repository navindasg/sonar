# Sonar — example environment.
# Copy to .env (gitignored) and fill locally, or prefer the macOS Keychain.
# NEVER put real secrets in this file. This repo is PUBLIC.

# ── Harness ──
HARNESS_HOST=127.0.0.1
HARNESS_PORT=8080

# ── Models (Ollama; both already pulled) ──
OLLAMA_HOST=http://127.0.0.1:11434
MODEL_FAST=gemma4:e4b-mlx
MODEL_REASON=gemma4:26b-mlx

# ── Obsidian vault (NOTE the space in the default path) ──
SONAR_VAULT_PATH=/Users/navindasgupta/Documents/Obsidian Vault

# ── Web search (pick one — see docs/DECISIONS.md open item) ──
BRAVE_API_KEY=
TAVILY_API_KEY=

# ── Push (ntfy) ──
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# ── Google OAuth (Gmail sign-in; desktop app client) ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Microsoft Graph (Outlook sign-in; public client / MSAL) ──
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT=common
