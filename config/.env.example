# Sonar — example environment.
# Copy to .env (gitignored) and fill locally, or prefer the macOS Keychain.
# NEVER put real secrets in this file. This repo is PUBLIC.

# ── Harness ──
HARNESS_HOST=127.0.0.1
HARNESS_PORT=8080

# ── Models (Ollama; both already pulled) ──
OLLAMA_HOST=http://127.0.0.1:11434
MODEL_FAST=gemma4:e4b-mlx
MODEL_REASON=gemma4:26b-mlx

# ── Obsidian vault (NOTE the space in the default path) ──
SONAR_VAULT_PATH=/Users/navindasgupta/Documents/Obsidian Vault

# ── Web search (web.search tool; vendor-agnostic) ──
# Provider: "tavily" (default; 1,000 free/mo, no card) or "searxng" (self-hosted,
# free, private). Brave dropped its free tier, Google CSE closed to new signups,
# Bing's API is retired — so tavily/searxng are the free-and-good options (2026).
SONAR_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
# For SONAR_SEARCH_PROVIDER=searxng: your local SearXNG with JSON output enabled.
SONAR_SEARXNG_URL=http://127.0.0.1:8888

# ── Push (ntfy) ──
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# ── Google OAuth (Gmail + Calendar read; per-user Desktop-app client, no admin) ──
# Sonar uses a Desktop-app OAuth client + installed-app flow (NOT a service
# account / domain-wide delegation, which is the only path needing a Workspace
# admin). Save the client-secret JSON at the path below and run:
#   scripts/sonar.sh google-auth   (one browser consent; token self-refreshes)
# Setup steps: harness/sonar_harness/google_auth.py docstring.
SONAR_GOOGLE_CLIENT_SECRET=/Users/navindasgupta/.config/sonar/google_client_secret.json
SONAR_GOOGLE_TOKEN=/Users/navindasgupta/.config/sonar/google_token.json

# ── Microsoft Graph (Outlook sign-in; public client / MSAL) ──
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT=common
